# NextAuth JWT Secret (сгенерируйте: openssl rand -base64 32)
AUTH_SECRET=your-secret-key-here

# Database (для локальной разработки)
DATABASE_URL=postgresql://user:password@localhost:5432/cashback_db

# Production URL
NEXTAUTH_URL=https://cashback.doroninva.ru

# Порт приложения
PORT=3010

# Admin user (для создания первого пользователя при деплое)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production
